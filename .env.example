# Supabase credentials (PUBLIC values only - safe in the browser bundle).
# Get these from: Supabase project -> Settings -> API Keys (publishable) + Data API (URL).
# Copy this file to .env and fill in your values before running dev/build.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxx
