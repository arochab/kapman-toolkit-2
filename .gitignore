# env - never commit credentials
.env
.env.*
!.env.example

# secrets - never commit any downloaded key / secret file
*secret*
*client_secret*
client_secrets*
*.pem
*.key

# build output
dist/
dist-ssr/

# dependencies
node_modules/

# editor / OS
.DS_Store
Thumbs.db
*.local

# local dev tooling (not shared)
.claude/

# vite cache
.vite/

# stray edit artifacts
*.head
*.orig

# cycle runner state (local only - not shared)
reports/.cycle-count

# Internal scaffolding — kept local, never published
PROJECT-STATUS.md
COMMS.md
GO-LIVE-CHECKLIST.md
SETUP.md
tasks/
scripts/
.claude/wf-*.js
.tmp-dsp/
