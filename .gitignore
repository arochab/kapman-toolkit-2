# env - never commit credentials
.env
.env.*
!.env.example

# secrets - never commit any downloaded key / secret file
*secret*
*client_secret*
client_secrets*
*.pem
*.key

# build output
dist/
dist-ssr/

# dependencies
node_modules/

# editor / OS
.DS_Store
Thumbs.db
*.local

# local dev tooling (not shared)
.claude/

# vite cache
.vite/

# stray edit artifacts
*.head
*.orig

# cycle runner state + reports (local only - not shared)
reports/

# rendered social videos (heavy binaries, kept local — the generator HTML IS committed)
assets/story/*.mp4

# Supabase CLI local link state (machine-specific, no secrets but not for the repo)
supabase/.temp/
supabase/.branches/

# Internal scaffolding — kept local, never published
PROJECT-STATUS.md
COMMS.md
GO-LIVE-CHECKLIST.md
SETUP.md
tasks/
scripts/
.claude/wf-*.js
.tmp-dsp/
CLAUDE.md
